# ============================================================
# 死ぬまでにやりたいこと100 — 環境変数テンプレート
# cp .env.local.example .env.local して各値を埋める
# ============================================================

# ── Neon Postgres ────────────────────────────────────────────
# https://console.neon.tech → New Project → Connection string
DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Clerk (認証) ─────────────────────────────────────────────
# https://dashboard.clerk.com → Create App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Clerk Dashboard → Webhooks → Add Endpoint (URL: /api/webhooks/clerk)
CLERK_WEBHOOK_SECRET=whsec_...
# Clerk routing
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Stripe (決済) ─────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Stripe Dashboard → Products → Create product → ¥980/月 → Price ID
STRIPE_PRO_PRICE_ID=price_...
# Stripe Dashboard → Webhooks → Add endpoint (URL: /api/webhooks/stripe)
# Events: customer.subscription.created, .updated, .deleted
STRIPE_WEBHOOK_SECRET=whsec_...

# ── AI エージェント ───────────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── App ──────────────────────────────────────────────────────
# 本番URL（Vercelデプロイ後に更新）
NEXT_PUBLIC_BASE_URL=http://localhost:3000
